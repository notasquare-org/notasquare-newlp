---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = `Not a Square｜お知らせ`;
const description = `Not a Square（NaS AI）からのお知らせ・最新情報を掲載しています。`;

// お知らせ一覧（新しい順）。追加するときはここに 1 件追記するだけで OK。
const news = [
  {
    date: '2026.06.22',
    cat: 'サービス',
    title: 'サイトを公開しました',
    body: 'Not a Square（NaS AI）のサイトを公開しました。FDE（Forward Deployed Engineer）として、現場に入り込み「一番ムダな業務」から自動化する事業内容をご紹介しています。',
  },
];

// 実際に存在するカテゴリだけをフィルターとして表示する（空のタブを出さない）。
const categories = ['すべて', ...Array.from(new Set(news.map((n) => n.cat)))];
---

<BaseLayout title={title} description={description} active="news">

<section class="page-hero">
  <div class="container">
    <div class="en hero-anim">NEWS</div>
    <h1 class="hero-anim d1">お知らせ</h1>
    <div class="breadcrumb hero-anim d2"><a href="/">ホーム</a> ／ お知らせ</div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div style="max-width:820px;margin:0 auto">
      <!-- filters -->
      <div class="news-filters reveal" role="group" aria-label="お知らせの絞り込み">
        {categories.map((cat, i) => (
          <button
            type="button"
            class={`filter-pill${i === 0 ? ' active' : ''}`}
            data-filter={i === 0 ? 'all' : cat}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >{cat}</button>
        ))}
      </div>

      <div class="news-list">
        {news.map((item) => (
          <div class="acc-item reveal" data-cat={item.cat}>
            <button class="acc-q" type="button" aria-expanded="false">
              <span style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
                <span style="font-size:12.5px;color:#6B7079;font-weight:500">{item.date}</span>
                <span class="tag-pill" style="font-size:10.5px;padding:2px 9px">{item.cat}</span>
                {item.title}
              </span>
              <svg class="ic" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            </button>
            <div class="acc-a"><div class="inner">{item.body}</div></div>
          </div>
        ))}
      </div>

      <p class="news-empty">該当するお知らせはありません。</p>
    </div>
  </div>
</section>

</BaseLayout>
