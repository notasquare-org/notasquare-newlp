---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = `Not a Square｜資料ダウンロード`;
const description = `NaSのサービス資料を無料でダウンロードいただけます。`;

// ▼ Googleフォームの「埋め込みURL」に差し替えてください
//   Googleフォーム → 送信 → <> (埋め込み) → src="..." の値をここに貼り付け
const GOOGLE_FORM_URL = 'https://docs.google.com/forms/d/e/1FAIpQLScVPdacWOsoXlDQ63FByfgP5e0zCWx_i-X_oql9uEN2xE8UoA/viewform?embedded=true';
---

<BaseLayout title={title} description={description} breadcrumb={[{ name: '資料ダウンロード' }]}>

<section class="page-hero">
  <div class="container">
    <div class="en hero-anim">DOWNLOAD</div>
    <h1 class="hero-anim d1">資料ダウンロード</h1>
    <div class="breadcrumb hero-anim d2"><a href="/">ホーム</a> ／ 資料ダウンロード</div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:flex-start" class="grid-2">
      <!-- left -->
      <div class="reveal-left">
        <h2 style="font-size:23px;font-weight:700;margin:0 0 18px;line-height:1.6">3分でわかる、<br>NaS AI サービス紹介資料</h2>
        <p style="font-size:14px;color:#3A3F47;line-height:2;margin:0 0 26px">サービス概要・支援内容・料金プラン・導入事例をまとめた資料を無料でダウンロードいただけます。社内検討用にぜひご活用ください。</p>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:14px">
          <li style="display:flex;gap:11px;font-size:14px"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#14233F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg>サービスの全体像と支援の流れ</li>
          <li style="display:flex;gap:11px;font-size:14px"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#14233F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg>料金プランと導入費用の目安</li>
          <li style="display:flex;gap:11px;font-size:14px"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#14233F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"/></svg>業種別の活用イメージ</li>
        </ul>
        <div style="margin-top:30px;background:#F4F7FE;border-radius:8px;padding:22px;display:flex;align-items:center;gap:18px">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#14233F" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/><path d="M10 12h5M10 15h5"/></svg>
          <div style="font-size:13px;color:#3A3F47;line-height:1.7">PDF形式 / 全12ページ<br>無料・登録後すぐにダウンロード</div>
        </div>
      </div>
      <!-- form (Googleフォーム埋め込み) -->
      <div class="reveal" style="background:#fff;border:1px solid #e3e5e9;border-radius:10px;padding:24px 20px;box-shadow:0 14px 34px rgba(28,59,117,.07)">
        <div style="font-size:16px;font-weight:700;margin:0 8px 14px">ダウンロードフォーム</div>
        <iframe
          src={GOOGLE_FORM_URL}
          title="資料ダウンロードフォーム"
          width="100%"
          height="1100"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          style="border:0;display:block;width:100%">読み込み中…</iframe>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
