---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = `FDEとは｜現場常駐で成果まで伴走するAI支援｜Not a Square`;
const description = `FDE（Forward Deployed Engineer）とは何か。現場に入り込み、成果が出るところまで伴走するNaSの支援スタイルをご紹介します。`;

// 「FDEとは」を、AI（AI Overview等）が用語定義として引用しやすい形で構造化する。
const fdeSchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: 'FDE（Forward Deployed Engineer）',
  description:
    'FDE（Forward Deployed Engineer）とは、顧客の現場に深く入り込み、課題の発見から実装・定着までを一気通貫で支援するエンジニア。「作って終わり」ではなく、成果が出るところまで責任を持つ働き方を指す。',
  inLanguage: 'ja',
};
---

<BaseLayout title={title} description={description} active="fde" breadcrumb={[{ name: 'FDEとは' }]} schema={fdeSchema}>

<section class="page-hero">
  <div class="container">
    <div class="en hero-anim">What is FDE?</div>
    <h1 class="hero-anim d1">FDEとは</h1>
    <div class="breadcrumb hero-anim d2"><a href="/">ホーム</a> ／ FDEとは</div>
  </div>
</section>

<!-- ===== INTRO ===== -->
<section class="sec">
  <div class="container">
    <div class="intro-lead" style="max-width:780px;margin:0 auto;text-align:center">
      <div class="reveal" style="font-size:13px;font-weight:700;letter-spacing:.2em;color:#93b9ef">Forward Deployed Engineer</div>
      <h2 class="reveal intro-h" style="font-size:27px;font-weight:700;line-height:1.6;margin:14px 0 24px">FDE<br>=現場に入り込み、成果まで伴走するエンジニア。</h2>
      <p class="reveal intro-p" style="font-size:15px;color:#3A3F47;line-height:2.1;margin:0;white-space:nowrap">FDE（Forward Deployed Engineer）とは、お客様の現場に深く入り込み、課題の発見から実装・定着までを一気通貫で支援するエンジニアです。<br>「作って終わり」ではなく成果が出るところまで責任を持つ——それがNaSの考えるFDEのあり方です。</p>
    </div>
  </div>
</section>

<!-- ===== DIFFERENCE ===== -->
<section class="sec sec-light">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-en sm">DIFFERENCE</div>
      <div class="sec-jp">従来の支援との違い</div>
      <div class="sec-rule"></div>
    </div>

    <div class="cmp reveal">
      <!-- ヘッダー -->
      <div class="cmp-row cmp-head">
        <div class="cmp-axis"></div>
        <div class="cmp-cell cmp-old">従来のコンサル／受託開発</div>
        <div class="cmp-cell cmp-nas"><img class="cmp-logo" src="/uploads/header_logo.png" alt="NaS">NaSのFDE</div>
      </div>

      <!-- 行1 -->
      <div class="cmp-row">
        <div class="cmp-axis">関わり方</div>
        <div class="cmp-cell cmp-old">
          <svg class="ic ic-x" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
          <span>提案・納品で関係が終わりがち</span>
        </div>
        <div class="cmp-cell cmp-nas">
          <svg class="ic ic-check" viewBox="0 0 24 24"><path d="M4 12l5 5L20 6"/></svg>
          <span>定着・成果が出るまで伴走</span>
        </div>
      </div>

      <!-- 行2 -->
      <div class="cmp-row">
        <div class="cmp-axis">距離感</div>
        <div class="cmp-cell cmp-old">
          <svg class="ic ic-x" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
          <span>現場とのズレが生まれやすい</span>
        </div>
        <div class="cmp-cell cmp-nas">
          <svg class="ic ic-check" viewBox="0 0 24 24"><path d="M4 12l5 5L20 6"/></svg>
          <span>現場に常駐し、本質課題を解決</span>
        </div>
      </div>

      <!-- 行3 -->
      <div class="cmp-row">
        <div class="cmp-axis">資産化</div>
        <div class="cmp-cell cmp-old">
          <svg class="ic ic-x" viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
          <span>社内にノウハウが残らない</span>
        </div>
        <div class="cmp-cell cmp-nas">
          <svg class="ic ic-check" viewBox="0 0 24 24"><path d="M4 12l5 5L20 6"/></svg>
          <span>社内に自走できる人材を残す</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cmp{
    max-width:940px;margin:0 auto;
    display:flex;flex-direction:column;gap:12px;
  }
  .cmp-row{
    display:grid;grid-template-columns:96px 1fr 1fr;
    gap:14px;align-items:stretch;
  }
  /* 中央＝観点ラベル */
  .cmp-axis{
    display:flex;align-items:center;justify-content:center;
    font-size:12.5px;font-weight:700;color:var(--navy);text-align:center;
  }
  /* セル共通 */
  .cmp-cell{
    display:flex;align-items:center;gap:11px;
    padding:18px 22px;border-radius:14px;
    font-size:14px;line-height:1.6;
  }
  /* 従来側 */
  .cmp-old{background:#fff;border:1px solid #e3e5e9;color:#6B7079}
  /* NaS側（ハイライト：明るいブルー） */
  .cmp-nas{
    color:var(--navy);
    background:linear-gradient(135deg,#eef4ff 0%,#dce6fb 100%);
    border:1px solid #c5d6f5;
    box-shadow:0 14px 30px -18px rgba(66,120,240,.5);
  }
  /* ヘッダー行 */
  .cmp-head .cmp-cell{
    padding:13px 22px;font-weight:700;font-size:13px;letter-spacing:.05em;
  }
  .cmp-head .cmp-old{color:#6B7079}
  .cmp-head .cmp-nas{color:var(--navy)}
  .cmp-logo{height:20px;width:auto;margin-right:11px;flex-shrink:0}
  /* アイコン */
  .ic{width:19px;height:19px;flex-shrink:0;fill:none;stroke-width:2.4;
      stroke-linecap:round;stroke-linejoin:round}
  .ic-x{stroke:#c0c5d6}
  .ic-check{stroke:#1F6E4A}

  @media(max-width:720px){
    /* イントロ：nowrapを解除して折り返す（横スクロール防止） */
    .intro-p{white-space:normal !important;text-align:left;font-size:14.5px !important;line-height:1.95 !important}
    .intro-p br{display:none}
    .intro-h{font-size:22px !important;line-height:1.55 !important}

    /* 比較表：スマホは1カラムに積んで読みやすく */
    .cmp{gap:22px}
    .cmp-head{display:none}
    .cmp-row{grid-template-columns:1fr;gap:8px}
    .cmp-axis{
      grid-column:1 / -1;justify-content:flex-start;
      font-size:14px;margin:0 0 2px;
    }
    .cmp-cell{position:relative;overflow:visible;padding:16px 16px 14px;font-size:13.5px}
    /* 1カラム化で消えるヘッダーの代わりに、各カードへ帰属ラベルを付与 */
    .cmp-old::before,.cmp-nas::before{
      position:absolute;top:-9px;left:14px;
      font-size:10.5px;font-weight:700;letter-spacing:.04em;
      padding:2px 9px;border-radius:20px;line-height:1.4;
    }
    .cmp-old::before{content:"従来";background:#eef0f3;color:#8b909b;border:1px solid #e3e5e9}
    .cmp-nas::before{content:"NaSのFDE";background:#dce6fb;color:var(--navy);border:1px solid #c5d6f5}
  }
</style>

<section class="cta-band">
  <div class="container">
    <div class="reveal-left">
      <div class="ttl">FDEの伴走支援を体感してください。</div>
      <div class="sub">まずは無料相談で、御社の可能性をお聞かせください。</div>
    </div>
    <div class="actions reveal">
      <a href="/download" class="btn btn-pill btn-pill-blue">
        資料をダウンロード
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 11l5 4 5-4M5 21h14"/></svg>
      </a>
      <a href="/consultation" class="btn btn-pill btn-pill-warm">
        無料相談を申し込む
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

</BaseLayout>
