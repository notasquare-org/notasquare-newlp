---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = `Not a Square｜無料相談`;
const description = `NaSの無料相談・無料診断のお申し込みフォーム。AI活用の可能性を無料で診断します。`;

// ▼ 酒井さんのGoogleカレンダー「予約スケジュール」の公開ページURLに差し替えてください
const BOOKING_URL = 'https://calendar.app.google/EhPJ1ucVFE7hha1R7';
---

<BaseLayout title={title} description={description} breadcrumb={[{ name: '無料相談' }]}>

<section class="page-hero">
  <div class="container">
    <div class="en hero-anim">CONSULTATION</div>
    <h1 class="hero-anim d1">無料相談</h1>
    <div class="breadcrumb hero-anim d2"><a href="/">ホーム</a> ／ 無料相談</div>
  </div>
</section>

<!-- ===== STEPS ===== -->
<section class="sec">
  <div class="container">
    <div style="max-width:760px;margin:0 auto 40px;text-align:center">
      <h2 class="reveal" style="font-size:24px;font-weight:700;margin:0 0 16px">まずはお気軽にご相談ください</h2>
      <p class="reveal" style="font-size:14.5px;color:#3A3F47;line-height:2;margin:0">「何から始めればいいか分からない」段階でも大丈夫です。ヒアリングをもとに、御社のAI活用の可能性を無料で診断します。</p>
    </div>
    <div class="grid-3" style="text-align:center;margin-bottom:10px">
      <div class="reveal"><div style="width:60px;height:60px;border-radius:50%;background:#F4F7FE;color:#14233F;font-size:20px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 14px">1</div><div style="font-size:15px;font-weight:700;margin-bottom:8px">日程を選ぶ</div><p style="font-size:12.5px;color:#3A3F47;margin:0;line-height:1.85">予約カレンダーから空いている日時を選択します。</p></div>
      <div class="reveal" data-delay="1"><div style="width:60px;height:60px;border-radius:50%;background:#F4F7FE;color:#14233F;font-size:20px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 14px">2</div><div style="font-size:15px;font-weight:700;margin-bottom:8px">予約確定</div><p style="font-size:12.5px;color:#3A3F47;margin:0;line-height:1.85">ご入力のメールに面談URL付きの確認が届きます。</p></div>
      <div class="reveal" data-delay="2"><div style="width:60px;height:60px;border-radius:50%;background:#F4F7FE;color:#14233F;font-size:20px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 14px">3</div><div style="font-size:15px;font-weight:700;margin-bottom:8px">無料診断</div><p style="font-size:12.5px;color:#3A3F47;margin:0;line-height:1.85">オンライン面談でAI活用の可能性を診断します。</p></div>
    </div>
  </div>
</section>

<!-- ===== BOOKING ===== -->
<section class="sec sec-light">
  <div class="container">
    <div class="reveal" style="max-width:680px;margin:0 auto;background:#fff;border:1px solid #e3e5e9;border-radius:10px;padding:44px 36px;box-shadow:0 14px 34px rgba(28,59,117,.07);text-align:center">
      <div style="font-size:17px;font-weight:700;margin-bottom:14px">オンラインで日程を予約する</div>
      <p style="font-size:14px;color:#3A3F47;line-height:2;margin:0 0 28px">下のボタンから予約カレンダーを開き、ご都合のよい日時をお選びください。<br>所要時間は30分程度・オンライン（Google Meet）で実施します。</p>
      <a href={BOOKING_URL} target="_blank" rel="noopener" class="btn btn-primary" style="justify-content:center;display:inline-flex">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
        予約カレンダーを開く
      </a>
      <p style="font-size:12px;color:#8A909A;margin:22px 0 0">予約完了後、ご入力のメールアドレスに面談URL付きの確認メールが届きます。</p>
    </div>
  </div>
</section>

</BaseLayout>
