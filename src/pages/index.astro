---
// トップページ。共通の枠は BaseLayout に任せ、
// ここにはこのページ固有の中身だけを書きます。
import BaseLayout from '../layouts/BaseLayout.astro';

// ヒーロー背景のスライドショー画像（建物・握手・チーム・AI活用 などを順に切替）。
const heroBase = 'https://images.unsplash.com/';
// PC用は横長、スマホ用は縦構図でトリミング（被写体を中央に残して余白なく全面表示）。
const heroQuery = '?fm=jpg&q=80&w=1800&auto=format&fit=crop';
const heroQueryMobile = '?fm=jpg&q=80&w=820&h=1180&fit=crop&crop=center&auto=format';
// スマホ用の縦トリミングを個別に上書き（被写体が中央から外れる画像だけ）。
const heroQueryMobileOverrides = {
  // 「AI」の文字が右寄りなので、中央トリミングだと「A」しか入らない。焦点を右へ寄せて AI 両方を収める。
  'photo-1677442136019-21780ecad995': '?fm=jpg&q=80&w=820&h=1180&fit=crop&crop=focalpoint&fp-x=0.68&fp-y=0.5&auto=format',
};
const heroPhotos = [
  'photo-1486406146926-c627a92ad1ab', // 都市・建物
  'photo-1677442136019-21780ecad995', // AI（タイポグラフィ）
  'photo-1639762681485-074b7f938ba0', // AIアブストラクト（3Dキューブ・ネットワーク）
  'photo-1655720828018-edd2daec9349', // AIアブストラクト（ネットワーク）
  'photo-1460925895917-afdab827c52f', // データ・分析ダッシュボード
  'photo-1526374965328-7f61d4dc18c5', // デジタルコード（マトリックス風）
  'photo-1488998427799-e3362cec87c3', // デスク（ノート・PC）
];
const heroImages = heroPhotos.map((p) => `${heroBase}${p}${heroQuery}`);
const heroImagesMobile = heroPhotos.map((p) => `${heroBase}${p}${heroQueryMobileOverrides[p] || heroQueryMobile}`);

// スライドショーのタイミングを枚数から自動計算（無地の区間が出ないように）。
const slideSlot = 5;                          // 1枚あたりの表示秒数
const heroCycle = heroImages.length * slideSlot; // 1周の長さ（秒）
const fadeIn = (1 / heroCycle) * 100;            // 約1秒でフェードイン
const hold   = (slideSlot / heroCycle) * 100;    // 表示しっぱなしの区間
const fadeOut = ((slideSlot + 1.5) / heroCycle) * 100; // 約1.5秒でフェードアウト

// REASON（選ばれる理由）の4項目。
// 画像を public/uploads/ に reason-01.png 〜 reason-04.png として置いたら、
// 下の imagesReady を true にすると、プレースホルダーから実際の画像に切り替わります。
const imagesReady = true;
const reasons = [
  { num: '01', title: '常駐で伴走支援',     desc: '週1日から専属チームが御社に入り、現場に寄り添って課題を解決します。',                 img: '/uploads/reason-01.png' },
  { num: '02', title: '実装までやり切る',   desc: '提案だけで終わらせず、動く仕組みをつくり、成果創出までコミットします。',               img: '/uploads/reason-02.png' },
  { num: '03', title: '定着まで支援',       desc: '現場に定着する仕組み化と運用サポートで、継続的な成果を生み出します。',               img: '/uploads/reason-03.png' },
  { num: '04', title: '自走できる状態へ',   desc: 'エンタープライズ水準の技術力で、御社が自分たちでAIを使いこなせる状態まで支援します。', img: '/uploads/reason-04.png' },
];

// SERVICE（事業内容）の2項目。short は円（ベン図）に入れる短いラベル。
const services = [
  { title: 'FDEによる業務改善', en: 'FDE',        short: '業務改善<br>（初期実装〜伴走保守）', anchor: '/service#service-01', desc: '現場に入り込み、一番ムダな業務から自動化。初期実装で余白を生み、月額の伴走・保守で定着させます。' },
  { title: 'AIセミナー',         en: 'AI seminer', short: '法人向けAIセミナー', anchor: '/service#service-02', desc: 'AI活用を学べるセミナーを企画・開催（名称は準備中）。経営者・現場担当者に、明日から使える基礎と実践をお届けします。' },
];
// 円の配置（左・右の2つ）。
const vennPos = ['pos-left', 'pos-right'];

// よくあるご質問（Q&A）。
// ここを唯一の情報源にして、下のアコーディオン表示と FAQPage 構造化データ（JSON-LD）の
// 両方をこの配列から生成します（両者が食い違わないように）。
const faqs = [
  {
    q: '個人事業とのことですが、契約は問題ない？',
    a: '適格請求書発行事業者（インボイス対応・登録番号 T3810366982257）です。NDAを締結し、フリーランス新法に準拠した契約で進めます（法人化も並行準備中）。',
  },
  {
    q: '社内データの扱いが不安です。',
    a: '取り扱い範囲は着手前にNDA・契約で個別に合意します。御社環境内で完結させる構成も、外部の高性能AIへ安全に渡す構成も、要件に合わせて設計。「どこに・何を出すか」を曖昧にしないのが原則です。',
  },
  {
    q: 'IT導入補助金は使えますか？',
    a: 'ツール導入部分は対象になり得ます（補助率1/2〜4/5）。御社で使えるかは無料相談で判定します。受託の自動化部分は原則対象外なので、そこは正直にお伝えします。',
  },
  {
    q: 'いくら・どれくらいかかりますか？',
    a: '無料診断は¥0から。現状を把握する本診断を経て初期実装を行い、その後の継続運用は月額プラン（Basic 15万円〜・税別）からお選びいただけます。正確な費用は、無料相談と本診断でご提案します。',
  },
  {
    q: '何から始めればいい？',
    a: '30分の無料相談から。業務を伺い、AIで解ける余地があるか一緒に見極めます。',
  },
];
---

<BaseLayout
  title="Not a Square（NaS AI）｜雇わずに持てる、御社専属のAI部門。"
  description="Not a Square（NaS AI／ナスAI・ノットアスクエア）は、AI開発者が現場に入り込み「一番ムダな業務」から自動化するFDE（Forward Deployed Engineer）。空いた時間と人を新規事業・本業強化へ転換します。京阪神および関西一円に対応。"
  faq={faqs}
>

<!-- ===== HERO ===== -->
<section class="hero2">
  <div class="hero2-slides" aria-hidden="true">
    {heroImages.map((src, i) => (
      <div
        class="hero2-slide"
        style={`--bg-d:url("${src}");--bg-m:url("${heroImagesMobile[i]}");animation-duration:${heroCycle}s;animation-delay:${i * slideSlot}s`}
      ></div>
    ))}
  </div>
  <style is:inline set:html={`@keyframes heroSlide{
    0%{opacity:0;transform:scale(1.05)}
    ${fadeIn.toFixed(2)}%{opacity:1}
    ${hold.toFixed(2)}%{opacity:1}
    ${fadeOut.toFixed(2)}%{opacity:0;transform:scale(1.13)}
    100%{opacity:0;transform:scale(1.13)}
  }`}></style>
  <div class="hero2-overlay"></div>
  <div class="hero2-inner">
    <div class="hero-anim hero2-eyebrow">AI × WORKFLOW</div>
    <h1 class="hero-anim d1 hero2-title">雇わずに持てる、<br>御社専属のAI部門。</h1>
    <p class="hero-anim d2 hero2-sub">『ドキュメントを渡して終わり』ではありません。<br>AI開発者が現場に入り込み、「一番ムダな業務」から自動化。<br>空いた時間と人を、新規事業・本業強化へ。<br>御社のワークフローそのものを変えるFDE企業です。</p>
    <div class="hero-anim d3 hero2-actions">
      <a href="/download" class="btn btn-pill btn-pill-blue">
        資料をダウンロード
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 11l5 4 5-4M5 21h14"/></svg>
      </a>
      <a href="/consultation" class="btn btn-pill btn-pill-warm">
        無料相談を申し込む
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>

  <style is:inline>
    .hero2{position:relative;min-height:100vh;min-height:100svh;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden}
    .hero2-slides{position:absolute;inset:0}
    /* 表示秒数と1周の長さはページ側で枚数から計算（animation-duration / delay をインラインで付与） */
    .hero2-slide{position:absolute;inset:0;opacity:0;background-image:var(--bg-d);background-size:cover;background-position:center;transform-origin:center;will-change:opacity,transform;animation-name:heroSlide;animation-timing-function:ease-in-out;animation-iteration-count:infinite}
    @media(prefers-reduced-motion:reduce){.hero2-slide{animation:none}.hero2-slide:first-child{opacity:1}}
    .hero2-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(12,22,48,.58),rgba(12,22,48,.40) 45%,rgba(12,22,48,.68))}
    .hero2-inner{position:relative;z-index:2;max-width:880px;padding:130px 32px}
    .hero2-eyebrow{font-size:13px;font-weight:700;letter-spacing:.24em;color:#cfe0ff;margin:0 0 22px}
    .hero2-title{font-size:54px;line-height:1.42;font-weight:700;color:#fff;margin:0 0 26px;letter-spacing:.02em;text-shadow:0 2px 24px rgba(0,0,0,.3)}
    .hero2-sub{font-size:16px;color:#e9eefb;line-height:2.05;margin:0 auto 40px;max-width:720px;text-shadow:0 1px 14px rgba(0,0,0,.4)}
    .hero2-actions{display:flex;gap:18px;justify-content:center;flex-wrap:wrap}
    @media(max-width:760px){
      .hero2{min-height:calc(100vh - 66px);min-height:calc(100svh - 66px)}
      .hero2-slide{background-image:var(--bg-m)}
      .hero2-inner{padding:88px 22px 80px}
      .hero2-title{font-size:32px;line-height:1.5}
      .hero2-sub{font-size:14.5px}
      /* ヒーロー直下のセクションだけ上余白を控えめにする（他セクション・PCは変更なし） */
      .hero2 + .sec{padding-top:44px}
    }
  </style>
</section>

<!-- ===== SERVICE ===== -->
<section id="service" class="sec sec-light">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-en">SERVICE</div>
      <div class="sec-jp">事業内容</div>
      <div class="sec-rule"></div>
    </div>
    <p class="reveal" style="max-width:760px;margin:0 auto 56px;text-align:center;font-size:15px;color:#3A3F47;line-height:2.1">御社専属のAI部門として、業務改善の実装から学びの場づくりまで。<br>単発の開発で終わらせず、現場で成果が出る状態を一緒につくります。</p>

    <div class="service-layout reveal">
      <!-- 3つの円（ベン図／クリックで各事業セクションへ） -->
      <div class="service-venn">
        {services.map((s, i) => (
          <a href={s.anchor} class={`venn-circle ${vennPos[i]}`} aria-label={`${s.title}を見る`}>
            <div class="venn-inner">
              <div class="venn-en">{s.en}</div>
              <div class="venn-jp" set:html={s.short}></div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="reveal" style="text-align:center;margin-top:48px">
      <a href="/service" class="btn btn-ghost">事業内容をくわしく見る →</a>
    </div>
  </div>

  <style is:inline>
    .service-layout{display:flex;justify-content:center;max-width:980px;margin:0 auto}
    /* ----- ベン図（クリック可能な2つの円） ----- */
    .service-venn{position:relative;width:100%;max-width:520px;aspect-ratio:520/300;margin:0 auto}
    .venn-circle{--x:0;position:absolute;top:50%;aspect-ratio:1/1;border-radius:50%;border:1.5px solid rgba(20,35,63,.32);background:rgba(255,255,255,.55);display:flex;align-items:center;justify-content:center;text-align:center;text-decoration:none;cursor:pointer;will-change:transform;transform:translate(var(--x),-50%);transition:border-color .35s,background .35s,box-shadow .35s,transform .35s cubic-bezier(.2,.7,.2,1)}
    /* 配置（左・右の2つを重ねる）。FDE（左）をメイン事業として大きく強調、AIセミナー（右）は小さく */
    .venn-circle.pos-left{left:0;width:68%;z-index:2;border-color:rgba(20,35,63,.5);background:rgba(255,255,255,.7);box-shadow:0 14px 36px rgba(16,32,63,.14);animation:vennFloatL 6s ease-in-out infinite}
    .venn-circle.pos-right{right:0;width:46%;animation:vennFloatR 6.5s ease-in-out -1.6s infinite}
    @keyframes vennFloatL{
      0%,100%{transform:translate(0,-50%)}
      50%{transform:translate(-7px,-50%)}
    }
    @keyframes vennFloatR{
      0%,100%{transform:translate(0,-50%)}
      50%{transform:translate(7px,-50%)}
    }
    /* ホバー／フォーカス：揺れを止め、濃紺で塗り、拡大し強調 */
    .venn-circle:hover,.venn-circle:focus-visible{animation:none;border-color:#14233F;background:#14233F;box-shadow:0 22px 48px rgba(16,32,63,.28);transform:translate(0,-50%) scale(1.07);z-index:3;outline:none}
    .venn-circle:hover .venn-en,.venn-circle:focus-visible .venn-en{color:#fff}
    .venn-circle:hover .venn-jp,.venn-circle:focus-visible .venn-jp{color:#cfe0ff}
    .venn-inner{padding:0 8px;transition:transform .35s}
    .venn-circle.pos-left .venn-inner{transform:translateX(-20%)}
    .venn-circle.pos-right .venn-inner{transform:translateX(24%)}
    .venn-en{font-size:24px;font-weight:800;color:#14233F;letter-spacing:.01em;line-height:1.1;transition:color .35s}
    .venn-jp{font-size:13px;font-weight:600;color:#6B7079;margin-top:7px;transition:color .35s}
    /* 小さい円（AIセミナー）はラベルも控えめに */
    .venn-circle.pos-right .venn-en{font-size:18px}
    .venn-circle.pos-right .venn-jp{font-size:11px;margin-top:5px}
    @media(prefers-reduced-motion:reduce){.venn-circle{animation:none}}
    @media(max-width:860px){
      .service-venn{max-width:420px}
      .venn-en{font-size:20px}
      .venn-circle.pos-right .venn-en{font-size:16px}
    }
  </style>
</section>

<!-- ===== REASON ===== -->
<section class="sec">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-en">REASON</div>
      <div class="sec-jp">NaSが選ばれる理由</div>
      <div class="sec-rule"></div>
    </div>
    <div class="reason-grid">
      {reasons.map((r) => (
        <div class="reason-item reveal">
          <div class="reason-head">
            <span class="reason-num">{r.num}</span>
            <h3 class="reason-title">{r.title}</h3>
          </div>
          <div class="reason-illust">
            {imagesReady
              ? <img src={r.img} alt={r.title} />
              : (
                <div class="reason-illust-ph">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.8"/><path d="M3 16l5-4 4 3 3-2 6 5"/></svg>
                  <span>{r.img.split('/').pop()}</span>
                </div>
              )}
          </div>
          <p class="reason-desc">{r.desc}</p>
        </div>
      ))}
    </div>

    <style is:inline>
      .reason-grid{display:grid;grid-template-columns:1fr 1fr;gap:46px 56px}
      .reason-head{display:flex;align-items:center;gap:20px;margin-bottom:4px}
      .reason-num{font-size:72px;font-weight:700;font-style:italic;line-height:1;color:transparent;-webkit-text-stroke:1.6px #14233F;letter-spacing:.02em;flex:none}
      .reason-title{font-size:25px;font-weight:700;color:#1a2b4a;line-height:1.4;margin:0}
      .reason-illust{margin:22px 0 24px;display:flex;align-items:center;justify-content:center}
      .reason-illust img{width:100%;max-width:480px;height:auto;display:block}
      .reason-illust-ph{width:100%;max-width:480px;aspect-ratio:4/3;background:#f4f7fc;border:1.5px dashed #c5d2e6;border-radius:14px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:#9aa7bd}
      .reason-illust-ph span{font-size:12.5px;letter-spacing:.04em}
      .reason-desc{font-size:14.5px;color:#3A3F47;line-height:2;margin:0}
      @media(max-width:760px){
        .reason-grid{grid-template-columns:1fr;gap:40px}
        .reason-num{font-size:60px}
        .reason-title{font-size:22px}
      }
    </style>
  </div>
</section>

<!-- ===== FLOW ===== -->
<section id="flow" class="sec sec-light">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-en">FLOW</div>
      <div class="sec-jp">導入の流れ</div>
      <div class="sec-rule"></div>
    </div>
    <div class="flow-diagram reveal">
      <div class="flow-axis"><span>導入フロー</span></div>
      <div class="flow-steps">
        <div class="flow-step" style="--c:#cdd9e9;--t:#eef3f9;--tc:#14233F;--nc:#14233F">
          <div class="flow-bar">
            <span class="flow-num">01</span>
            <span class="flow-title">無料診断</span>
          </div>
          <div class="flow-desc">ヒアリングをもとに、AI活用の可能性を無料で診断します。</div>
        </div>
        <div class="flow-step" style="--c:#5b7596;--t:#e8eef6;--tc:#fff;--nc:#5b7596" data-delay="1">
          <div class="flow-bar">
            <span class="flow-num">02</span>
            <span class="flow-title">ヒアリング</span>
          </div>
          <div class="flow-desc">現状の課題や業務フローを丁寧にヒアリングし、最適なAI活用戦略をご提案します。</div>
        </div>
        <div class="flow-step" style="--c:#14233F;--t:#e3e7ef;--tc:#fff;--nc:#14233F" data-delay="2">
          <div class="flow-bar">
            <span class="flow-num">03</span>
            <span class="flow-title">初期実装＋月額運用</span>
          </div>
          <div class="flow-desc">初期実装で余白を生み、月額の伴走・保守で本格運用と継続的な改善を支援。成果の最大化と定着を図ります。</div>
        </div>
      </div>
    </div>
  </div>

  <style is:inline>
    .flow-diagram{display:flex;gap:16px;align-items:stretch;max-width:920px;margin:0 auto}
    .flow-axis{flex:none;width:58px;background:linear-gradient(180deg,#97a1bb,#79849f);border-radius:6px 6px 0 0;clip-path:polygon(0 0,100% 0,100% calc(100% - 30px),50% 100%,0 calc(100% - 30px));display:flex;align-items:center;justify-content:center;padding:22px 0 44px}
    .flow-axis span{writing-mode:vertical-rl;text-orientation:upright;color:#fff;font-size:17px;font-weight:700;letter-spacing:.3em}
    .flow-steps{flex:1;display:flex;flex-direction:column;gap:10px;min-width:0}
    .flow-step{display:flex;align-items:stretch;min-height:96px}
    .flow-bar{flex:0 0 50%;min-width:0;background:var(--c);color:var(--tc,#fff);display:flex;align-items:center;gap:20px;padding:16px 20px;clip-path:polygon(0 0,calc(100% - 30px) 0,100% 50%,calc(100% - 30px) 100%,0 100%);margin-right:-30px;position:relative;z-index:2}
    .flow-num{flex:none;width:52px;height:64px;background:#fff;border-radius:9px;color:var(--nc,var(--c));display:flex;align-items:center;justify-content:center;font-size:23px;font-weight:800;letter-spacing:.02em;box-shadow:0 1px 4px rgba(20,35,63,.12)}
    .flow-title{font-size:21px;font-weight:700;letter-spacing:.04em}
    .flow-desc{flex:1;min-width:0;background:var(--t);display:flex;align-items:center;padding:16px 26px 16px 50px;font-size:13.5px;line-height:1.85;color:#2a2f37}
    @media(max-width:760px){
      .flow-diagram{flex-direction:column;gap:8px}
      .flow-axis{width:auto;height:46px;flex-direction:row;border-radius:6px;clip-path:polygon(0 0,calc(100% - 24px) 0,100% 50%,calc(100% - 24px) 100%,0 100%);padding:0 24px 0 18px;justify-content:flex-start}
      .flow-axis span{writing-mode:horizontal-tb;letter-spacing:.2em;font-size:15px}
      .flow-step{flex-direction:column;min-height:0}
      .flow-bar{flex:none;margin-right:0;clip-path:polygon(0 0,100% 0,100% calc(100% - 16px),50% 100%,0 calc(100% - 16px));padding:16px 18px 26px;z-index:2}
      .flow-desc{padding:22px 18px 16px;margin-top:-10px}
    }
  </style>
</section>

