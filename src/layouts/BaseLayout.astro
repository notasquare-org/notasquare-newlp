---
// 全ページ共通の「枠」。
// title / description / active を各ページから受け取ります。
// ogImage は SNS シェア時のサムネ画像（未指定ならデフォルト画像）。
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description, active, ogImage = '/uploads/titleogo.png' } = Astro.props;

// canonical / OGP 用の絶対URLを組み立てる。
// Astro.site（astro.config の site）を基準に、現在ページのパスで正規URLを作る。
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// 会社情報の構造化データ（JSON-LD / Organization）。
// Google に事業者名・URL・ロゴを正しく伝える。
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Not a Square',
  alternateName: 'NaS AI',
  url: Astro.site?.toString(),
  logo: new URL('/uploads/titleogo.png', Astro.site).toString(),
  description:
    'AI開発者が現場に入り込み「一番ムダな業務」から自動化するFDE（Forward Deployed Engineer）。京阪神および関西一円に対応。',
  areaServed: '京阪神および関西一円',
};
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Google Search Console の所有権確認タグ（HTMLタグ方式） -->
  <meta name="google-site-verification" content="i5f8387lJ9-1nbAEgjihuCXNY-I3NS3WtZJ3ah-j9Jc">
  <link rel="icon" type="image/png" href="/uploads/titleogo.png">
  <link rel="apple-touch-icon" href="/uploads/titleogo.png">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- 正規URL（重複URLの評価分散を防ぐ） -->
  <link rel="canonical" href={canonicalURL}>

  <!-- OGP（Facebook / LINE などSNSシェア時の表示） -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Not a Square">
  <meta property="og:locale" content="ja_JP">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:image" content={ogImageURL}>

  <!-- Twitter（X）カード -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageURL}>

  <!-- 構造化データ（会社情報 / JSON-LD） -->
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>

  <Header active={active} />

  <!-- ↓↓↓ 各ページ固有の中身が、ここに差し込まれます ↓↓↓ -->
  <slot />
  <!-- ↑↑↑ -->

  <Footer />

  <button class="to-top" aria-label="ページ上部へ戻る">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V6M6 12l6-6 6 6"/></svg>
  </button>

  <script is:inline src="/assets/main.js"></script>
</body>
</html>
