---
// 全ページ共通の「枠」。
// title / description / active を各ページから受け取ります。
// ogImage は SNS シェア時のサムネ画像（未指定ならデフォルト画像）。
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// 会社の基本情報は src/data/company.ts に集約（法人化・移転時はそこだけ更新）。
import { company } from '../data/company';

// faq       … 渡すと FAQPage 構造化データを出力（Q&Aのあるページのみ）
// breadcrumb… [{ name, path? }] を渡すと BreadcrumbList を出力（ホームは自動で先頭に付与）
// schema    … 任意の JSON-LD オブジェクト（配列可）をそのまま追加出力（Article / DefinedTerm など）
const { title, description, active, ogImage = '/uploads/ogp.png', faq, breadcrumb, schema } = Astro.props;

// canonical / OGP 用の絶対URLを組み立てる。
// Astro.site（astro.config の site）を基準に、現在ページのパスで正規URLを作る。
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// 会社情報の構造化データ（JSON-LD / Organization）。
// Google・生成AI（AI Overview等）に事業者の実在性と概要を正しく伝える。
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: company.name,
  alternateName: company.alternateName,
  url: Astro.site?.toString(),
  logo: new URL(company.logoPath, Astro.site).toString(),
  description: company.description,
  // 所在地（AIが「実在する事業者」と判断するための重要シグナル）
  address: {
    '@type': 'PostalAddress',
    ...company.address,
  },
  // 対応エリア（地域クエリでの引用を狙う）
  areaServed: company.areaServed.map((name) => ({ '@type': 'Place', name })),
  // 問い合わせ手段
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: company.email,
    areaServed: 'JP',
    availableLanguage: 'Japanese',
  },
  // 代表者（E-E-A-T：誰が運営しているかを明示）
  founder: {
    '@type': 'Person',
    name: company.founderName,
  },
  // 適格請求書発行事業者 登録番号（実在の識別子）
  identifier: {
    '@type': 'PropertyValue',
    name: '適格請求書発行事業者 登録番号',
    value: company.invoiceRegistrationNumber,
  },
};

// FAQ 構造化データ（faq プロップが渡されたページのみ出力）。
// AI Overview / リッチリザルトのFAQ枠に、質問と回答のペアとして認識させる。
const faqJsonLd = faq
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

// パンくず構造化データ（breadcrumb プロップが渡されたページのみ）。
// 先頭に「ホーム」を自動付与。path 未指定の項目（＝現在ページ）は canonical を使う。
const breadcrumbJsonLd = breadcrumb
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [{ name: 'ホーム', path: '/' }, ...breadcrumb].map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.name,
        item: (c.path ? new URL(c.path, Astro.site) : canonicalURL).toString(),
      })),
    }
  : null;

// ページ固有の追加スキーマ（Article / DefinedTerm など）。配列でも単体でも受ける。
const extraSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Google Search Console の所有権確認タグ（HTMLタグ方式） -->
  <meta name="google-site-verification" content="i5f8387lJ9-1nbAEgjihuCXNY-I3NS3WtZJ3ah-j9Jc">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="512x512" href="/uploads/favicon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/uploads/apple-touch-icon.png">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- 正規URL（重複URLの評価分散を防ぐ） -->
  <link rel="canonical" href={canonicalURL}>

  <!-- OGP（Facebook / LINE などSNSシェア時の表示） -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Not a Square">
  <meta property="og:locale" content="ja_JP">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:image" content={ogImageURL}>
  <meta property="og:image:secure_url" content={ogImageURL}>
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={title}>

  <!-- Twitter（X）カード -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageURL}>
  <meta name="twitter:image:alt" content={title}>

  <!-- 構造化データ（会社情報 / JSON-LD） -->
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

  <!-- 構造化データ（よくある質問 / FAQPage）。faq を渡したページだけ出力 -->
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

  <!-- 構造化データ（パンくず / BreadcrumbList）。breadcrumb を渡したページだけ出力 -->
  {breadcrumbJsonLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />}

  <!-- 構造化データ（ページ固有 / Article・DefinedTerm など） -->
  {extraSchemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/style.css?v=20260710">
</head>
<body>

  <Header active={active} />

  <!-- ↓↓↓ 各ページ固有の中身が、ここに差し込まれます ↓↓↓ -->
  <slot />
  <!-- ↑↑↑ -->

  <Footer />

  <button class="to-top" aria-label="ページ上部へ戻る">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V6M6 12l6-6 6 6"/></svg>
  </button>

  <script is:inline src="/assets/main.js"></script>
</body>
</html>
